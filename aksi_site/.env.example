# Leave OPENAI_API_KEY empty to use the free Pollinations provider.
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4.1-mini
FREE_MODEL=openai
BOT_SYSTEM_PROMPT=Ты АКСИ-бот: тёплый, поддерживающий, честный ассистент. Помогай в делах, планировании и общении.
AKSI_IDENTITY=Баширова Альфия Ринатовна. Дата рождения: 14.02.1995, 08:10, Россия, Татарстан, Нурлат.
# Optional: set this to enable verifiable HMAC-SHA256 signatures from /api/identity.
AKSI_INSTANCE_ID=aksi-local
AKSI_SIGNING_SECRET=
AKSI_SIGNATURE_CLAIM=АКСИ — персональный AI-ассистент Башировой Альфии Ринатовны: предназначение, фокус, память, заметки, web-контекст и диагностика.
